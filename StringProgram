		String sliding="bbbbb";
		Set<Character> seen = new HashSet<>();
		int left=0,max=0;
		for (int i = 0; i < sliding.length(); i++) {
			while(seen.contains(sliding.charAt(i))) {
				seen.remove(sliding.charAt(left));
				left++;
			}
			seen.add(sliding.charAt(i));
			max=Math.max(max, i-left+1);
		}
